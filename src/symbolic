class SymNorm:
    
    def __init__(self, K, k_bounds=(1,'m'), l_bounds=(1,'m'), verbose=True, use_t=True):
        
        self.K = K
        self.use_t = use_t
        self.k_bounds = k_bounds
        self.l_bounds = l_bounds
        
        m, n, r = symbols('m n r')       # m is number of rows of S, and n > m
        
        s = IndexedBase('s')        # row s
        S = IndexedBase('S')        # submatrix excluding s
        savg = IndexedBase('savg')  # <s>
        
        i, j, k, l = symbols('i j k l', integer=True, positive=True)
        
        ## Define norms
        new = ( (S[i,k] - savg[i] - (s[i]-savg[i])/n)*(S[i,l] - savg[i] - (s[i]-savg[i])/n)
                   *(S[j,k] - savg[j] - (s[j]-savg[j])/n)*(S[j,l] - savg[j] - (s[j]-savg[j])/n) )
        
        old = ( (S[i,k] - savg[i])*(S[i,l] - savg[i])
               *(S[j,k] - savg[j])*(S[j,l] - savg[j]) )
        
        ## Functions for numerical evaluation
        if verbose:
            print('Compiling functions')

        self.newf = sp.lambdify([S, s, n, m, r], self.prelambdify(new))
        self.oldf = sp.lambdify([S, n, m, r], self.prelambdify(old))
        
        ## Simplified symbolic expression
        if verbose:
            print('Rearraning sums')
        self.qf_new, self.lf_new, self.cf_new = self.rearrange(new, k_bounds, l_bounds)
        self.qf_old, self.lf_old, self.cf_old = self.rearrange(old, k_bounds, l_bounds)
    
        ## Get equations
        qf = sum([a*x*s[i]*s[j] for a,x in self.qf_new.items()])
        lf = sum([a*x*s[i] for a,x in self.lf_new.items()])
        cf = sum([a*x for a,x in self.cf_new.items()])
        
        if verbose:
            print('Plugging in K')
        self.new_quad = sp.Sum(qf, (i,1,K), (j,1,K)).doit()
        self.new_lin = sp.Sum(lf, (i,1,K), (j,1,K)).doit()
        self.new_const = sp.Sum(cf, (i,1,K), (j,1,K)).doit()
        self.old_const = sp.Sum(sum([a*x for a,x in self.cf_old.items()]), (i,1,K), (j,1,K)).doit()
        
        # self.newf = sp.lambdify(, self.new_quad + 2*self.new_lin + self.new_const)
        
    def __call__(self, Sval, sval, m_val):
        
        r_val, n_val = Sval.shape
        return self.newf(Sval, sval, n_val, m_val, r_val) - self.oldf(Sval, n_val, m_val, r_val)
    
    def prelambdify(self, summand):
         
        m, n, r = symbols('m n r')
        i, j, k, l = symbols('i j k l', integer=True, positive=True)
        S = IndexedBase('S')        # submatrix excluding s
        savg = IndexedBase('savg')  # <s>
        
        ## Computer scientists are obsessed with 0 indexing so even
        ## this symbolic math package requires it even though it makes
        ## no damned sense in this context I hate it
        stupid_k_bounds = (k, self.k_bounds[0]-1, self.k_bounds[1]+'-1')
        stupid_l_bounds = (l, self.l_bounds[0]-1, self.l_bounds[1]+'-1')
        
        subsum = summand.subs(savg[i], sp.Sum(S[i,k], (k,0,n-1))/(n-1))
        subsum = subsum.subs(savg[j], sp.Sum(S[j,k], (k,0,n-1))/(n-1))
    
        summed = sp.Sum(subsum, (i,0,r-1), (j,0,r-1), stupid_k_bounds, stupid_l_bounds)
        return expand(factor_terms(expand(summed))).doit()
    
