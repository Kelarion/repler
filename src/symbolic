    def sub(self, C_vals, savg_vals, stst_vals, s_vals, n_val):
        
        m, n = symbols('m n')           # m is number of rows of S, and n > m

        s = IndexedBase('s')            # row s
        savg = IndexedBase('savg')      # <s>
        stst = IndexedBase('stst')      # <s>_{test}
        C = IndexedBase('C')            # <ss'>_{test}
        
        subs_dict = {n: n_val}
        for row_idx in range(self.K):
            subs_dict[savg[row_idx+1]] = savg_vals[row_idx]
            subs_dict[stst[row_idx+1]] = stst_vals[row_idx]
            subs_dict[s[row_idx+1]] = s_vals[row_idx]
            for col_idx in range(self.K):
                subs_dict[C[row_idx+1, col_idx+1]] = C_vals[row_idx, col_idx]
        
        return subs_dict

    def rearrange(self, summand, k_bounds, l_bounds):
                
        ## Have to redefine the symbols
        m, n = symbols('m n')       # m is number of rows of S, and n > m
        i, j, k, l = symbols('i j k l', integer=True, positive=True)     
        s = IndexedBase('s')        # row s

        ## Normalize to remove m
        self.k_sum = sp.Sum(1, (k,)+k_bounds).doit()
        self.l_sum = sp.Sum(1, (l,)+l_bounds).doit()
        denom = self.k_sum*self.l_sum

        ## Rearrange the summation
        expr = expand(summand/denom)
        
        summed = sp.Sum(expr, (k,)+k_bounds)
        
        summed = expand(factor_terms(expand(summed))).doit()
        full_sum = expand(factor_terms(expand(sp.Sum(summed, (l,)+l_bounds)))).doit()
        
        ##
        
        ## Introduce moment variables and apply idempotence
        result = full_sum
        
        ## Make substitutions according to the predefined dictionary
        for this_sum in result.find(sp.Sum):
            for pre,post in mts.items():
                fn = this_sum.match(pre)
                if fn is not None:
                    result = result.subs(this_sum, post.subs(fn))
       
        for idx in [i,j]:
            result = result.subs(s[idx]**2, s[idx])
        
        self.vars = [x for x in result.free_symbols if isinstance(x, sp.Indexed)]
        
        ## Gather terms
        # Quadratic terms
        quad_terms = self.get_monomials(result.coeff(s[i]*s[j]))
        
        # Linear terms (this is multiplied by 2)
        lin_terms = self.get_monomials(result.subs(s[i],0).coeff(s[j]))

        # constant
        const_terms = self.get_monomials(result.subs({s[i]:0, s[j]:0}))
        
        return quad_terms, lin_terms, const_terms

    def get_monomials(self, expr):
        
        if self.use_t:                  # useful shorthand 
            n, t = symbols('n, t')
        
        poly = Poly(expr, *self.vars)
        out_dict = {}
        for powers, cfs in poly.as_dict().items():
            term = sp.prod([g**e for g,e in zip(poly.gens, powers)])
            if self.use_t:
                out_dict[term] = sp.factor(cfs).subs((n-1)/n, t).simplify()
        
        return out_dict